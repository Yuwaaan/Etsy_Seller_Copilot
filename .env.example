# Copy this file to .env and fill in real values. Never commit .env.

# --- Business Analyst Agent (LLM reasoning/planning) ---
# The app works fully without any of these -- without a configured key, the
# Business Analyst Agent (and the "AI Insights" narrative) automatically
# falls back to a deterministic, rule-based engine. Set ONE of the two API
# keys below to enable LLM-powered reasoning and recommendations.
#
# Provider is auto-detected from whichever key is set (Anthropic takes
# priority if both are set). Set MODEL_PROVIDER to force one explicitly.
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Etsy API credentials ---
ETSY_API_KEY=
ETSY_API_SECRET=
ETSY_SHOP_ID=

# --- Optional: LangSmith tracing for debugging LangGraph runs ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=etsy-seller-copilot
